# Core runtime
NODE_ENV=development
DATABASE_URL=file:./prisma/dev.db
ROLE_RADAR_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
AUTH_SECRET=replace-with-a-long-random-string
REVIEW_QUEUE_TOKEN=replace-with-a-local-token

# Optional analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Gemini / fallback providers
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENABLED=1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_ENABLED=0
BRAVE_SEARCH_API_KEY=
ROLE_RADAR_ROLE_REFRESH_SCHEDULE=

# Optional human verification for watchlist auth
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=your_from_email@example.com
SMTP_FROM_NAME=role-radar
TLS_MODE=ssl

# Logging
ROLE_RADAR_LOG_PATH=tmp/logs/role-radar.log
ROLE_RADAR_LOG_LEVEL=info

# Daily ops
ROLE_RADAR_DAILY_ENABLE_ROLE_DISCOVERY=0
ROLE_RADAR_DAILY_ROLE_DISCOVERY_LIMIT=5
